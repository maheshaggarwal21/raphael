{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "raphael/lesson/v1",
  "title": "Raphael lesson v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "slug",
    "title",
    "status",
    "category",
    "severity",
    "scope",
    "triggers",
    "lesson",
    "evidence",
    "provenance",
    "injection"
  ],
  "properties": {
    "schema": { "const": "raphael/lesson/v1" },
    "id": {
      "type": "string",
      "pattern": "^les_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 60
    },
    "title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 80
    },
    "status": {
      "enum": ["candidate", "active", "probation", "retired", "archived", "quarantined"]
    },
    "category": {
      "enum": [
        "security",
        "correctness",
        "performance",
        "reliability",
        "process",
        "tooling",
        "api-design",
        "data"
      ]
    },
    "severity": { "enum": ["critical", "high", "medium", "low"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stacks": {
          "type": "array",
          "items": { "type": "string", "maxLength": 40 },
          "maxItems": 12
        },
        "task_kinds": {
          "type": "array",
          "items": { "type": "string", "maxLength": 40 },
          "maxItems": 12
        },
        "projects": {
          "type": "array",
          "items": { "type": "string", "maxLength": 80 },
          "maxItems": 40
        },
        "agents": {
          "type": "array",
          "items": {
            "enum": [
              "manager",
              "planner",
              "architect",
              "developer",
              "reviewer",
              "security",
              "debugger",
              "designer",
              "deployer",
              "critique"
            ]
          },
          "maxItems": 10,
          "uniqueItems": true
        }
      }
    },
    "triggers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": {
          "type": "array",
          "items": { "type": "string", "maxLength": 60 },
          "maxItems": 20
        },
        "paths": {
          "type": "array",
          "items": { "type": "string", "maxLength": 120 },
          "maxItems": 20
        }
      }
    },
    "lesson": {
      "type": "string",
      "minLength": 20,
      "maxLength": 700
    },
    "counter_indications": {
      "type": "string",
      "maxLength": 400
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observations", "distinct_projects"],
      "properties": {
        "refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ev_[0-9A-HJKMNP-TV-Z]{26}$" },
          "maxItems": 100
        },
        "observations": { "type": "integer", "minimum": 0 },
        "distinct_projects": { "type": "integer", "minimum": 0 },
        "source_mix": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mined": { "type": "integer", "minimum": 0 },
            "user_note": { "type": "integer", "minimum": 0 },
            "git": { "type": "integer", "minimum": 0 }
          }
        },
        "first_seen": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "last_seen": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "source_kind", "tier"],
      "properties": {
        "created_by": { "type": "string", "maxLength": 120 },
        "source_kind": {
          "enum": ["session-transcript", "git-history", "manual", "imported"]
        },
        "human_edited": { "type": "boolean" },
        "tier": { "enum": ["curated", "user", "auto"] }
      }
    },
    "injection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline"],
      "properties": {
        "headline": { "type": "string", "minLength": 10, "maxLength": 200 },
        "tokens": { "type": "integer", "minimum": 1, "maximum": 60 }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supersedes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^les_[0-9A-HJKMNP-TV-Z]{26}$" },
          "maxItems": 20
        },
        "related": {
          "type": "array",
          "items": { "type": "string", "pattern": "^les_[0-9A-HJKMNP-TV-Z]{26}$" },
          "maxItems": 20
        },
        "duplicates_merged": {
          "type": "array",
          "items": { "type": "string", "pattern": "^les_[0-9A-HJKMNP-TV-Z]{26}$" },
          "maxItems": 40
        }
      }
    }
  }
}
