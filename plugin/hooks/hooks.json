{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "raph inject --event session-start" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "raph inject --event user-prompt" }
        ]
      }
    ]
  }
}
